# Environment Configuration for Corvos BJJ Backend

# Node Environment
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Database
DATABASE_URL="postgresql://corvos:corvos_secure_pass_2026@localhost:5432/corvos_bjj_dev"
DB_USER=corvos
DB_PASSWORD=corvos_secure_pass_2026
DB_NAME=corvos_bjj_dev

# JWT Configuration
JWT_SECRET=seu-secret-super-seguro-min-32-caracteres-aleatorios-2024
JWT_EXPIRY=900s # 15 minutes in seconds
REFRESH_TOKEN_EXPIRY=7d # 7 days
# Compatibilidade com ambientes que usam nomenclatura *_EXPIRES_IN
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
RESET_TOKEN_EXPIRY=30m # Token de reset de senha

# Email Configuration (Optional)
EMAIL_SERVICE=sendgrid # or 'mailgun' or 'smtp'
EMAIL_API_KEY=SG.seu-sendgrid-api-key-aqui
EMAIL_FROM=noreply@corvosbjj.com

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3001

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000 # 15 minutes
RATE_LIMIT_MAX=100 # max requests per window per IP

# Optional: Logging
LOG_LEVEL=info # debug, info, warn, error

# Be sure to:
# 1. Change JWT_SECRET to a strong random value in production
# 2. Use environment-specific database URLs (dev, staging, prod)
# 3. Never commit .env file with real secrets to git
# 4. Use .env.local for local development overrides
